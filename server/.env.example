# ============================================================
# DATABASE CONNECTION (Supabase PostgreSQL)
# ============================================================
# Copy this file to .env dan isi nilai yang diperlukan
# 
# Cara mendapatkan DATABASE_URL di Supabase:
# 1. Buka https://supabase.com/dashboard
# 2. Pilih project → Project Settings → Database
# 3. Scroll ke "Connection string"
# 4. Pilih tab "Session Pooler"
# 5. Copy string berformat:
#    postgresql://postgres.PROJECT_ID:PASSWORD@pooler.REGION.supabase.com:5432/postgres
# ============================================================

# SESSION POOLER (IPv4 - RECOMMENDED)
# Format: postgresql://postgres.PROJECT_ID:PASSWORD@pooler.REGION.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.PROJECT_ID:YOUR_DB_PASSWORD@pooler.REGION.supabase.com:5432/postgres

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000
JWT_SECRET=YOUR_JWT_SECRET_CHANGE_ME
JWT_EXPIRES_IN=7d
