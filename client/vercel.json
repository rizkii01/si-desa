{
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://157.10.161.159:5000/api/:path*" },
    { "source": "/uploads/:path*", "destination": "http://157.10.161.159:5000/uploads/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
